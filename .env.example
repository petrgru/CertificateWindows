# OPNsense API Configuration
# Copy this to .env and fill in your values.
# The script reads .env from the same directory by default.

OPNSENSE_URL=http://192.168.1.1
OPNSENSE_API_KEY=your_api_key_here
OPNSENSE_API_SECRET=your_api_secret_here
OPNSENSE_CERT_NAME=
OPNSENSE_INSECURE=true
OPNSENSE_STORE_LOCATION=LocalMachine
OPNSENSE_STORE_NAME=Root
OPNSENSE_INCLUDE_PRIVATE_KEY=false
OPNSENSE_OUTPUT_DIR=.
